{
  "name": "omnistock",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "depcruise": "turbo depcruise",
    "validate": "turbo validate",
    "gen:contracts": "turbo gen:contracts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "dev": "pnpm db:up && pnpm --filter @omnistock/db exec prisma migrate deploy && turbo dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ]
  }
}
