{
  "name": "omnistock",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "depcruise": "turbo depcruise",
    "validate": "turbo validate",
    "gen:contracts": "turbo gen:contracts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "dev": "pnpm db:up && pnpm --filter @omnistock/db exec prisma migrate deploy && turbo dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
