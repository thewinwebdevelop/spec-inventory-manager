{
  "name": "api",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "check-env": "tsx scripts/check-env.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.27",
    "@omnistock/config": "workspace:*",
    "@omnistock/core-domain": "workspace:*",
    "@omnistock/db": "workspace:*",
    "@omnistock/contracts": "workspace:*",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@swc/core": "^1.10.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.1.8"
  }
}
