{
  "name": "@omnistock/contracts",
  "private": true,
  "version": "0.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "echo ok",
    "validate": "redocly lint openapi/openapi.yaml",
    "gen:contracts": "pnpm run gen:contracts:ts && pnpm run gen:contracts:dart",
    "gen:contracts:ts": "openapi-typescript openapi/openapi.yaml -o src/generated/ts/schema.d.ts --redocly redocly.codegen.yaml",
    "gen:contracts:dart": "bash scripts/gen-dart-client.sh",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --ignore-pattern \"src/generated/**\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.39.1",
    "@redocly/cli": "^2.37.0",
    "openapi-typescript": "^7.13.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  }
}
