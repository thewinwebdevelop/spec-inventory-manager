# OmniStock — environment variable shape contract (F-000 · T-000-02).
# Spec: docs/features/F-000/infra.md §8.1. This is the SHAPE contract, not a
# credential source — every value below is a placeholder. Copy to `.env`
# (gitignored) and adjust for your machine before running `apps/api`.
#
# Validated at boot by the zod schema in packages/config/src/env.ts (AC14).

# --- Database (Postgres, via docker-compose "postgres" service) -------------
DATABASE_URL="postgresql://omnistock:omnistock@localhost:5432/omnistock_dev?schema=public"

# --- Redis (via docker-compose "redis" service; consumed by BullMQ, T-000-08) -
REDIS_URL="redis://localhost:6379"

# --- Auth (placeholders — real secrets are never committed) -----------------
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"

# --- Runtime ------------------------------------------------------------------
PORT="3000"
NODE_ENV="development"
